{
  "name": "revolution-trading-pros-monorepo",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=24.14.1 || >=25.9.0",
    "pnpm": ">=10.6.5"
  },
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm --filter frontend build",
    "preview": "pnpm --filter frontend preview",
    "check": "pnpm --filter frontend check",
    "lint": "pnpm --filter frontend lint",
    "format": "pnpm --filter frontend format",
    "test": "pnpm --filter frontend test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ],
    "overrides": {
      "@tanstack/svelte-table>svelte": "^5.55.1"
    },
    "peerDependencyRules": {
      "ignoreMissing": ["@sveltejs/vite-plugin-svelte", "vite"],
      "allowedVersions": {
        "typescript": "6",
        "vite": "7"
      }
    }
  }
}