# ═══════════════════════════════════════════════════════════════════════════
# Revolution Trading Pros — Frontend (SvelteKit) environment template
# ═══════════════════════════════════════════════════════════════════════════
#
# SvelteKit reads three groups:
#
#   VITE_*       — bundled into the client. SAFE-FOR-BROWSER values only.
#                  Read via import.meta.env.VITE_X.
#   PUBLIC_*     — server-side, but allowed in client bundles via $env/static/public.
#                  Same browser-visibility rules as VITE_*.
#   (other)      — server-only. Read via $env/dynamic/private. Never bundled.
#
# Files (loaded in this order, later wins):
#   .env             checked into git, baseline non-secret defaults
#   .env.local       gitignored, dev override pointing at local Docker API
#   .env.production  checked in, prod URLs (no secrets)
#   .env.[mode]      per-Vite-mode overrides (rare)
#
# To run locally against the Docker stack:
#   cp .env.example .env.local      # then edit (or use values below)
# ═══════════════════════════════════════════════════════════════════════════

# ── API endpoints ───────────────────────────────────────────────────────────
# Browser-visible (Vite). Used by client-side fetch / WebSocket clients.
VITE_API_URL=http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080

# Server-only. Read by hooks.server.ts and proxy +server.ts files.
# We set both names because the codebase reads both for historical reasons —
# centralising under API_BASE_URL is on the cleanup backlog.
API_BASE_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080

# ── Site metadata ───────────────────────────────────────────────────────────
VITE_SITE_NAME=Revolution Trading Pros
VITE_SITE_URL=http://localhost:5173
VITE_SITE_DESCRIPTION=Master the markets with institutional-grade trading tools
VITE_DEFAULT_OG_IMAGE=/og-image-default.png
VITE_TWITTER_HANDLE=@RevTradingPros
VITE_FACEBOOK_APP_ID=

# ── CDN ─────────────────────────────────────────────────────────────────────
VITE_CDN_URL=https://pub-2e5bd1b702b440bd888a0fc47f3493ae.r2.dev

# ── Analytics & tracking (browser-visible, public IDs only) ─────────────────
VITE_GTM_ID=
VITE_GTAG_ID=
PUBLIC_GA4_MEASUREMENT_ID=
PUBLIC_META_PIXEL_ID=
PUBLIC_TIKTOK_PIXEL_ID=
PUBLIC_TWITTER_PIXEL_ID=
PUBLIC_LINKEDIN_PARTNER_ID=
PUBLIC_PINTEREST_TAG_ID=
PUBLIC_REDDIT_PIXEL_ID=

# ── Error tracking ──────────────────────────────────────────────────────────
# Public DSN is safe in the client bundle by Sentry's design.
VITE_SENTRY_DSN=

# ── Debug ───────────────────────────────────────────────────────────────────
VITE_ANALYTICS_DEBUG=false
