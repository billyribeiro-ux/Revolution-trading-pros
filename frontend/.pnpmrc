# Revolution Trading Pros - pnpm Configuration
# ICT 7 Principal Engineer Standards

# Use exact versions for reproducible builds
save-exact=true

# Allow legacy peer deps to handle transitive dependency conflicts
# Required for @fortawesome/svelte-fontawesome and other packages with outdated peer deps
legacy-peer-deps=true

# Ensure pnpm uses the correct registry
registry=https://registry.npmjs.org/

# Strict engine checks (disabled for camera-controls which requires Node 22+)
engine-strict=false
