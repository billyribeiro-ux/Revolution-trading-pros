{
	"name": "revolution-svelte",
	"version": "2.0.0",
	"description": "A SvelteKit project for Revolution.",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.10.0",
	"engines": {
		"node": ">=24.17.0",
		"pnpm": ">=11.10.0"
	},
	"scripts": {
		"dev": "vite dev",
		"dev:fast": "vite dev",
		"build": "vite build",
		"build:cloudflare": "DEPLOY_TARGET=cloudflare vite build",
		"build:static": "DEPLOY_TARGET=static vite build",
		"preview": "vite preview",
		"preview:component": "node scripts/preview-component.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:all": "NODE_OPTIONS='--max-old-space-size=4096' svelte-check",
		"check:types": "tsc --noEmit",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:strict": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:a11y": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings --compiler-warnings 'a11y_missing_attribute:error,a11y_label_has_associated_control:error,a11y_click_events_have_key_events:error,a11y_no_static_element_interactions:error,a11y_no_noninteractive_element_interactions:error'",
		"lint": "NODE_OPTIONS='--max-old-space-size=4096' eslint .",
		"lint:fix": "NODE_OPTIONS='--max-old-space-size=4096' eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest",
		"test:unit": "vitest run",
		"test:unit:ui": "vitest --ui",
		"test:unit:watch": "vitest watch",
		"test:coverage": "vitest run --coverage",
		"test:a11y": "playwright test tests/accessibility --project=chromium",
		"test:ci": "npm run test:unit",
		"analyze": "vite-bundle-visualizer",
		"deploy:cloudflare": "npm run build:cloudflare && wrangler pages deploy .svelte-kit/cloudflare",
		"deploy:preview": "npm run build:cloudflare && wrangler pages deploy .svelte-kit/cloudflare --branch preview",
		"ports:check": "lsof -i:5173 -i:5174 -i:8080 -i:5432 -i:6379 || echo 'No processes found on those ports'",
		"dev:clean": "lsof -ti:5173 | xargs kill -9 2>/dev/null; lsof -ti:5174 | xargs kill -9 2>/dev/null; pnpm dev",
		"dev:fresh": "docker compose down && docker compose up -d && pnpm dev:clean"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^1.15.0",
		"@stripe/stripe-js": "^7.0.0",
		"@tabler/icons-svelte-runes": "^3.31.0",
		"@threlte/core": "^8.6.0",
		"@threlte/extras": "^9.22.0",
		"@vimeo/player": "^2.26.1",
		"blurhash": "^2.0.5",
		"canvas-confetti": "^1.9.3",
		"d3": "^7.9.0",
		"diff-match-patch": "^1.0.5",
		"dompurify": "^3.2.5",
		"embla-carousel": "^8.6.3",
		"embla-carousel-autoplay": "^8.6.3",
		"embla-carousel-svelte": "^8.6.3",
		"gsap": "^3.13.0",
		"html2canvas": "^1.4.1",
		"isomorphic-dompurify": "^2.24.0",
		"lightweight-charts": "^5.3.0",
		"three": "^0.176.0",
		"tus-js-client": "^4.3.2",
		"typed.js": "^2.1.0",
		"valibot": "^1.2.0",
		"web-vitals": "^4.2.4",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.10.1",
		"@eslint/js": "^9.26.0",
		"@internationalized/date": "^3.8.0",
		"@paypal/paypal-js": "^9.0.0",
		"@playwright/test": "^1.52.0",
		"@square/web-payments-sdk-types": "^1.83.0",
		"@sveltejs/adapter-cloudflare": "^7.0.0",
		"@sveltejs/kit": "^2.25.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.4.2",
		"@testing-library/svelte": "^5.2.1",
		"@types/canvas-confetti": "^1.6.4",
		"@types/d3": "^7.4.3",
		"@types/d3-array": "^3.2.1",
		"@types/d3-axis": "^3.0.6",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-scale-chromatic": "^3.1.0",
		"@types/d3-selection": "^3.0.11",
		"@types/d3-shape": "^3.1.6",
		"@types/diff-match-patch": "^1.0.36",
		"@types/node": "^22.15.0",
		"@types/three": "^0.176.0",
		"@typescript-eslint/eslint-plugin": "^8.31.0",
		"@typescript-eslint/parser": "^8.31.0",
		"@vitest/browser-playwright": "^3.2.0",
		"@vitest/coverage-v8": "^3.2.0",
		"bits-ui": "^2.3.0",
		"clsx": "^2.1.1",
		"d3-array": "^3.2.4",
		"d3-axis": "^3.0.0",
		"d3-scale": "^4.0.2",
		"d3-scale-chromatic": "^3.1.0",
		"d3-selection": "^3.0.0",
		"d3-shape": "^3.2.0",
		"eslint": "^9.26.0",
		"eslint-config-prettier": "^10.1.0",
		"eslint-plugin-svelte": "^3.5.0",
		"globals": "^16.0.0",
		"magic-string": "^0.30.17",
		"playwright": "^1.52.0",
		"prettier": "^3.5.0",
		"prettier-plugin-svelte": "^3.3.3",
		"super-sitemap": "^1.0.0",
		"svelte": "^5.28.0",
		"svelte-check": "^4.2.0",
		"svelte-inspect-value": "^0.4.0",
		"tailwind-merge": "^3.2.0",
		"tailwind-variants": "^1.0.0",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.2.0",
		"typescript": "^5.8.0",
		"typescript-eslint": "^8.31.0",
		"vite": "^6.3.0",
		"vite-bundle-visualizer": "^1.2.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^3.2.0",
		"wrangler": "^4.15.0"
	}
}
