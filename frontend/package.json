{
	"name": "revolution-svelte",
	"version": "2.0.0",
	"description": "A SvelteKit project for Revolution.",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24.14.1",
		"pnpm": ">=10.8.0"
	},
	"scripts": {
		"dev": "vite dev",
		"dev:fast": "vite dev",
		"build": "vite build",
		"build:cloudflare": "DEPLOY_TARGET=cloudflare vite build",
		"build:static": "DEPLOY_TARGET=static vite build",
		"preview": "vite preview",
		"preview:component": "node scripts/preview-component.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:all": "NODE_OPTIONS='--max-old-space-size=4096' svelte-check",
		"check:types": "tsc --noEmit",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "NODE_OPTIONS='--max-old-space-size=4096' eslint .",
		"lint:fix": "NODE_OPTIONS='--max-old-space-size=4096' eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest",
		"test:ui": "playwright test --ui",
		"test:headed": "playwright test --headed",
		"test:unit": "vitest run",
		"test:unit:ui": "vitest --ui",
		"test:unit:watch": "vitest watch",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:routes": "playwright test tests/e2e/route-matrix.spec.ts --workers=1",
		"test:e2e:smoke": "playwright test tests/e2e/smoke --project=chromium",
		"test:e2e:auth": "playwright test tests/e2e/auth --project=chromium",
		"test:e2e:trading": "playwright test tests/e2e/trading-room --project=chromium",
		"test:e2e:checkout": "playwright test tests/e2e/checkout --project=chromium",
		"test:e2e:api": "PLAYWRIGHT_API_ONLY=1 playwright test tests/e2e/api --project=api --reporter=list",
		"test:e2e:chromium": "playwright test tests/e2e --project=chromium",
		"test:e2e:firefox": "playwright test tests/e2e --project=firefox",
		"test:e2e:webkit": "playwright test tests/e2e --project=webkit",
		"test:e2e:mobile": "playwright test tests/e2e --project=mobile-chrome --project=mobile-safari",
		"test:e2e:all": "playwright test tests/e2e --project=chromium --project=firefox --project=webkit",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:report": "playwright show-report",
		"test:a11y": "pa11y-ci",
		"test:visual": "playwright test tests/visual",
		"test:ci": "pnpm run test:unit && pnpm run test:e2e",
		"verify": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && pnpm run test:unit && playwright test tests/e2e --project=chromium",
		"mcp:svelte-autofixer": "svelte-mcp svelte-autofixer",
		"mcp:svelte-autofixer:all": "node scripts/run-svelte-autofixer.mjs",
		"test:blog-editor": "playwright test --project=blog-editor",
		"test:blog-editor:firefox": "playwright test --project=blog-editor-firefox",
		"test:blog-editor:mobile": "playwright test --project=blog-editor-mobile",
		"test:blog-editor:all": "playwright test --project=blog-editor --project=blog-editor-firefox --project=blog-editor-mobile",
		"test:blog-editor:visual": "playwright test --project=visual-regression",
		"test:blog-editor:a11y": "playwright test --project=accessibility",
		"analyze": "vite-bundle-visualizer",
		"deploy:cloudflare": "pnpm run build:cloudflare && wrangler pages deploy .svelte-kit/cloudflare",
		"deploy:preview": "pnpm run build:cloudflare && wrangler pages deploy .svelte-kit/cloudflare --branch preview"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.42.0",
		"@formkit/auto-animate": "^0.9.0",
		"@iconify-json/fa-solid": "^1.2.3",
		"@iconify-json/fa6-solid": "^1.2.3",
		"@iconify-json/heroicons": "^1.2.4",
		"@iconify-json/ph": "^1.2.3",
		"@iconify/svelte": "^4.2.0",
		"@stripe/stripe-js": "^7.1.0",
		"@tanstack/svelte-virtual": "^3.13.6",
		"@threlte/core": "^8.3.1",
		"@threlte/extras": "^9.5.2",
		"@tiptap/core": "^3.12.0",
		"@tiptap/extension-bubble-menu": "^3.12.0",
		"@tiptap/extension-character-count": "^3.12.0",
		"@tiptap/extension-code-block-lowlight": "^3.12.0",
		"@tiptap/extension-color": "^3.12.0",
		"@tiptap/extension-dropcursor": "^3.12.0",
		"@tiptap/extension-floating-menu": "^3.12.0",
		"@tiptap/extension-highlight": "^3.12.0",
		"@tiptap/extension-horizontal-rule": "^3.12.0",
		"@tiptap/extension-image": "^3.12.0",
		"@tiptap/extension-link": "^3.12.0",
		"@tiptap/extension-placeholder": "^3.12.0",
		"@tiptap/extension-subscript": "^3.12.0",
		"@tiptap/extension-superscript": "^3.12.0",
		"@tiptap/extension-table": "^3.12.0",
		"@tiptap/extension-table-cell": "^3.12.0",
		"@tiptap/extension-table-header": "^3.12.0",
		"@tiptap/extension-table-row": "^3.12.0",
		"@tiptap/extension-task-item": "^3.12.0",
		"@tiptap/extension-task-list": "^3.12.0",
		"@tiptap/extension-text-align": "^3.12.0",
		"@tiptap/extension-text-style": "^3.12.0",
		"@tiptap/extension-typography": "^3.12.0",
		"@tiptap/extension-underline": "^3.12.0",
		"@tiptap/extension-youtube": "^3.12.0",
		"@tiptap/pm": "^3.12.0",
		"@tiptap/starter-kit": "^3.12.0",
		"better-auth": "^1.2.0",
		"blurhash": "^2.0.5",
		"canvas-confetti": "^1.9.4",
		"d3": "^7.9.0",
		"diff-match-patch": "^1.0.5",
		"embla-carousel-autoplay": "^8.6.0",
		"embla-carousel-svelte": "^8.6.0",
		"gsap": "^3.14.2",
		"html2canvas": "^1.4.1",
		"isomorphic-dompurify": "^3.7.1",
		"lightweight-charts": "^5.1.0",
		"lottie-web": "^5.13.0",
		"svelte-click-to-source": "workspace:*",
		"three": "^0.182.0",
		"tus-js-client": "^4.3.2",
		"typed.js": "^3.0.0",
		"valibot": "^1.0.0",
		"vivus": "^0.4.6",
		"web-vitals": "^5.2.1",
		"y-indexeddb": "^9.0.12",
		"y-protocols": "^1.0.6",
		"y-websocket": "^3.0.6",
		"yjs": "^13.6.24"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.10.1",
		"@content-collections/core": "^0.11.4",
