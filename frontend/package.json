{
	"name": "revolution-svelte",
	"version": "2.0.0",
	"description": "A SvelteKit project for Revolution.",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
	"engines": {
		"node": ">=24.18.0",
		"pnpm": ">=11.5.2"
	},
	"scripts": {
		"dev": "vite dev",
		"dev:fast": "vite dev",
		"build": "vite build",
		"build:cloudflare": "DEPLOY_TARGET=cloudflare vite build",
		"build:static": "DEPLOY_TARGET=static vite build",
		"preview": "vite preview",
		"preview:component": "node scripts/preview-component.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:all": "NODE_OPTIONS='--max-old-space-size=4096' svelte-check",
		"check:types": "tsc --noEmit",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:strict": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:a11y": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings --compiler-warnings 'a11y_missing_attribute:error,a11y_label_has_associated_control:error,a11y_click_events_have_key_events:error,a11y_no_static_element_interactions:error,a11y_no_noninteractive_element_interactions:error'",
		"lint": "NODE_OPTIONS='--max-old-space-size=4096' eslint .",
		"lint:fix": "NODE_OPTIONS='--max-old-space-size=4096' eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest",
		"test:unit": "vitest run",
		"test:unit:ui": "vitest --ui",
		"test:unit:watch": "vitest watch",
		"test:coverage": "vitest run --coverage",
		"test:a11y": "playwright test tests/accessibility --project=chromium",
		"test:ci": "npm run test:unit",
		"analyze": "vite-bundle-visualizer",
		"deploy:cloudflare": "npm run build:cloudflare && wrangler pages deploy .svelte-kit/cloudflare",
		"deploy:preview": "npm run build:cloudflare && wrangler pages deploy .svelte-kit/cloudflare --branch preview",
		"ports:check": "lsof -i:5173 -i:5174 -i:8080 -i:5432 -i:6379 || echo 'No processes found on those ports'",
		"dev:clean": "lsof -ti:5173 | xargs kill -9 2>/dev/null; lsof -ti:5174 | xargs kill -9 2>/dev/null; pnpm dev",
		"dev:fresh": "docker compose down && docker compose up -d && pnpm dev:clean"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.110.0",
		"@stripe/stripe-js": "^9.9.0",
		"@tabler/icons-svelte-runes": "^3.44.0",
		"@threlte/core": "^8.5.16",
		"@threlte/extras": "^9.21.0",
		"@vimeo/player": "^2.30.4",
		"blurhash": "^2.0.5",
		"canvas-confetti": "^1.9.4",
		"d3": "^7.9.0",
		"diff-match-patch": "^1.0.5",
		"dompurify": "^3.4.11",
		"embla-carousel": "^8.6.0",
		"embla-carousel-autoplay": "^8.6.0",
		"embla-carousel-svelte": "^8.6.0",
		"gsap": "^3.15.0",
		"html2canvas": "^1.4.1",
		"isomorphic-dompurify": "^3.18.0",
		"lightweight-charts": "^5.2.0",
		"three": "^0.185.1",
		"tus-js-client": "^4.3.1",
		"typed.js": "^3.0.0",
		"valibot": "^1.4.2",
		"web-vitals": "^5.3.0"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.2",
		"@paypal/paypal-js": "^10.0.2",
		"@playwright/test": "^1.61.1",
		"@square/web-payments-sdk-types": "^1.83.11",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.4",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"@types/canvas-confetti": "^1.9.0",
		"@types/d3": "^7.4.3",
		"@types/d3-array": "^3.2.2",
		"@types/d3-axis": "^3.0.6",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-scale-chromatic": "^3.1.0",
		"@types/d3-selection": "^3.0.11",
		"@types/d3-shape": "^3.1.8",
		"@types/diff-match-patch": "^1.0.36",
		"@types/node": "^24.13.2",
		"@types/three": "^0.185.0",
		"@typescript-eslint/eslint-plugin": "^8.63.0",
		"@typescript-eslint/parser": "^8.63.0",
		"@vitest/browser-playwright": "^4.1.10",
		"@vitest/coverage-v8": "^4.1.10",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"d3-array": "^3.2.4",
		"d3-axis": "^3.0.0",
		"d3-scale": "^4.0.2",
		"d3-scale-chromatic": "^3.1.0",
		"d3-selection": "^3.0.0",
		"d3-shape": "^3.2.0",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"magic-string": "^0.30.21",
		"playwright": "^1.61.1",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"super-sitemap": "^2.0.4",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"svelte-inspect-value": "^0.11.3",
		"tailwindcss": "^4.3.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.3",
		"vite-bundle-visualizer": "^1.2.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.10",
		"wrangler": "^4.107.0"
	}
}
