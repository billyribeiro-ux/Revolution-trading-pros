{
	"name": "revolution-svelte",
	"version": "2.0.0",
	"description": "A SvelteKit project for Revolution.",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24.14.1",
		"pnpm": ">=10.6.5"
	},
	"scripts": {
		"dev": "vite dev",
		"dev:fast": "vite dev",
		"build": "vite build",
		"build:cloudflare": "DEPLOY_TARGET=cloudflare vite build",
		"build:static": "DEPLOY_TARGET=static vite build",
		"preview": "vite preview",
		"preview:component": "node scripts/preview-component.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:all": "NODE_OPTIONS='--max-old-space-size=4096' svelte-check",
		"check:types": "tsc --noEmit",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "NODE_OPTIONS='--max-old-space-size=4096' eslint .",
		"lint:fix": "NODE_OPTIONS='--max-old-space-size=4096' eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest",
		"test:ui": "playwright test --ui",
		"test:headed": "playwright test --headed",
		"test:unit": "vitest run",
		"test:unit:ui": "vitest --ui",
		"test:unit:watch": "vitest watch",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:smoke": "playwright test tests/e2e/smoke --project=chromium",
		"test:e2e:auth": "playwright test tests/e2e/auth --project=chromium",
		"test:e2e:trading": "playwright test tests/e2e/trading-room --project=chromium",
		"test:e2e:checkout": "playwright test tests/e2e/checkout --project=chromium",
		"test:e2e:api": "playwright test tests/e2e/api --project=api",
		"test:e2e:chromium": "playwright test tests/e2e --project=chromium",
		"test:e2e:firefox": "playwright test tests/e2e --project=firefox",
		"test:e2e:webkit": "playwright test tests/e2e --project=webkit",
		"test:e2e:mobile": "playwright test tests/e2e --project=mobile-chrome --project=mobile-safari",
		"test:e2e:all": "playwright test tests/e2e --project=chromium --project=firefox --project=webkit",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:report": "playwright show-report",
		"test:a11y": "pa11y-ci",
		"test:visual": "playwright test tests/visual",
		"test:ci": "pnpm run test:unit && pnpm run test:e2e",
		"test:blog-editor": "playwright test --project=blog-editor",
		"test:blog-editor:firefox": "playwright test --project=blog-editor-firefox",
		"test:blog-editor:mobile": "playwright test --project=blog-editor-mobile",
		"test:blog-editor:all": "playwright test --project=blog-editor --project=blog-editor-firefox --project=blog-editor-mobile",
		"test:blog-editor:visual": "playwright test --project=visual-regression",
		"test:blog-editor:a11y": "playwright test --project=accessibility",
		"analyze": "vite-bundle-visualizer",
		"deploy:cloudflare": "pnpm run build:cloudflare && wrangler pages deploy .svelte-kit/cloudflare",
		"deploy:preview": "pnpm run build:cloudflare && wrangler pages deploy .svelte-kit/cloudflare --branch preview"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.82.0",
		"@formkit/auto-animate": "^0.9.0",
		"@iconify/svelte": "5.2.1",
		"@stripe/stripe-js": "^9.0.1",
		"@tanstack/svelte-virtual": "^3.13.23",
		"@threlte/core": "^8.5.5",
		"@threlte/extras": "^9.14.3",
		"@tiptap/core": "3.22.2",
		"@tiptap/extension-bubble-menu": "3.22.2",
		"@tiptap/extension-character-count": "3.22.2",
		"@tiptap/extension-code-block-lowlight": "3.22.2",
		"@tiptap/extension-color": "3.22.2",
		"@tiptap/extension-dropcursor": "3.22.2",
		"@tiptap/extension-floating-menu": "3.22.2",
		"@tiptap/extension-highlight": "3.22.2",
		"@tiptap/extension-horizontal-rule": "3.22.2",
		"@tiptap/extension-image": "3.22.2",
		"@tiptap/extension-link": "3.22.2",
		"@tiptap/extension-placeholder": "3.22.2",
		"@tiptap/extension-subscript": "3.22.2",
		"@tiptap/extension-superscript": "3.22.2",
		"@tiptap/extension-table": "3.22.2",
		"@tiptap/extension-table-cell": "3.22.2",
		"@tiptap/extension-table-header": "3.22.2",
		"@tiptap/extension-table-row": "3.22.2",
		"@tiptap/extension-task-item": "3.22.2",
		"@tiptap/extension-task-list": "3.22.2",
		"@tiptap/extension-text-align": "3.22.2",
		"@tiptap/extension-text-style": "3.22.2",
		"@tiptap/extension-typography": "3.22.2",
		"@tiptap/extension-underline": "3.22.2",
		"@tiptap/extension-youtube": "3.22.2",
		"@tiptap/pm": "3.22.2",
		"@tiptap/starter-kit": "3.22.2",
		"better-auth": "1.5.6",
		"blurhash": "^2.0.5",
		"canvas-confetti": "^1.9.4",
		"d3": "^7.9.0",
		"diff-match-patch": "^1.0.5",
		"embla-carousel-autoplay": "^8.6.0",
		"embla-carousel-svelte": "^8.6.0",
		"gsap": "^3.14.2",
		"html2canvas": "^1.4.1",
		"isomorphic-dompurify": "^3.7.1",
		"lightweight-charts": "^5.1.0",
		"lottie-web": "^5.13.0",
		"svelte-click-to-source": "workspace:*",
		"three": "^0.183.2",
		"tus-js-client": "^4.3.1",
		"typed.js": "^3.0.0",
		"valibot": "^1.3.1",
		"vivus": "^0.4.6",
		"web-vitals": "^5.2.0",
		"y-indexeddb": "^9.0.12",
		"y-protocols": "^1.0.7",
		"y-websocket": "^3.0.0",
		"yjs": "^13.6.30"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@content-collections/core": "0.14.3",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.15.1",
		"@internationalized/date": "^3.12.0",
		"@opentelemetry/api": "^1.9.1",
		"@playwright/test": "^1.59.1",
		"@poppanator/sveltekit-svg": "6.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/enhanced-img": "0.10.4",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@sveltejs/vite-plugin-svelte-inspector": "^5.0.2",
		"@tanstack/svelte-query": "6.1.13",
		"@tanstack/svelte-table": "8.21.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/canvas-confetti": "^1.9.0",
		"@types/d3": "^7.4.3",
		"@types/d3-array": "^3.2.2",
		"@types/d3-axis": "^3.0.6",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-scale-chromatic": "^3.1.0",
		"@types/d3-selection": "^3.0.11",
		"@types/d3-shape": "^3.1.8",
		"@types/diff-match-patch": "^1.0.36",
		"@types/node": "^25.5.2",
		"@types/three": "0.183.1",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"@vitest/browser-playwright": "^4.1.2",
		"@vitest/coverage-v8": "^4.1.2",
		"altcha": "2.3.0",
		"bits-ui": "^2.17.1",
		"d3-array": "^3.2.4",
		"d3-axis": "^3.0.0",
		"d3-scale": "^4.0.2",
		"d3-scale-chromatic": "^3.1.0",
		"d3-selection": "^3.0.0",
		"d3-shape": "^3.2.0",
		"dotenv": "^17.4.0",
		"embla-carousel": "8.6.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"formsnap": "2.0.1",
		"globals": "^17.4.0",
		"magic-string": "^0.30.21",
		"mdsvex": "^0.12.7",
		"pa11y-ci": "^4.1.0",
		"phosphor-svelte": "3.1.0",
