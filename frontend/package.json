		"@inlang/paraglide-js": "^2.0.0",
		"@internationalized/date": "^3.8.0",
		"@opentelemetry/api": "^1.9.0",
		"@playwright/test": "^1.51.0",
		"@poppanator/sveltekit-svg": "^5.0.0",
