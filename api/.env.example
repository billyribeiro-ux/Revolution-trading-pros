# ═══════════════════════════════════════════════════════════════════════════
# Revolution Trading Pros — Rust API environment template
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy to api/.env and fill in real values. This file is gitignored.
# Every variable below is read by `std::env::var(...)` somewhere in api/src/.
# Variables marked OPTIONAL fall back to a default; the rest are REQUIRED.
#
# Auth-flavored secrets (JWT, OAuth, Postmark, Stripe) MUST be set in prod
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────────
# OPTIONAL — defaults: 8080 / "production"
PORT=8080
ENVIRONMENT=development
# OPTIONAL — used by emails as the link host (defaults to VITE_SITE_URL).
APP_URL=http://localhost:5173

# ── Datastore ───────────────────────────────────────────────────────────────
# REQUIRED. Local docker-compose default:
#   postgres://rtp:rtp_password@db:5432/revolution_trading_pros
DATABASE_URL=postgres://rtp:rtp_password@localhost:5432/revolution_trading_pros

# REQUIRED. Local docker-compose default: redis://redis:6379
REDIS_URL=redis://localhost:6379

# ── Auth ────────────────────────────────────────────────────────────────────
# REQUIRED. ≥ 32 chars. Used to sign access + refresh JWTs (HS256).
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-32-characters-long

# REQUIRED in production (≥ 32 chars, generate with `openssl rand -hex 32`).
# Key the HMAC for member download capability tokens and indicator license keys.
# Boot fails closed if unset/short/placeholder in production (RUST_DEEP_AUDIT P0-2/P1-3).
MEMBER_INDICATOR_SECRET=replace-me-with-a-long-random-secret-at-least-32-characters-long
MEMBER_LICENSE_SECRET=replace-me-with-a-long-random-secret-at-least-32-characters-long

# OPTIONAL — default 1 (hour). Access-token TTL.
# Kept short per OWASP guidance for sites handling PII/payments.
# Frontend must use the refresh-token flow to obtain a new access token.
JWT_EXPIRES_IN=1

# OPTIONAL — comma-separated. These users bypass email verification + are
# treated as superadmins by middleware/admin.rs. Not for prod.
DEVELOPER_EMAILS=
SUPERADMIN_EMAILS=
DEVELOPER_MODE=false

# OPTIONAL — bootstrap-seed a developer user on first boot. The hash is
# Argon2id (OWASP 2024 params). For local dev use api/scripts/seed-local-admin.sh
# instead — it's interactive and idempotent.
DEVELOPER_BOOTSTRAP_EMAIL=
DEVELOPER_BOOTSTRAP_NAME=
DEVELOPER_BOOTSTRAP_PASSWORD_HASH=

# ── OAuth (Google) ──────────────────────────────────────────────────────────
# OPTIONAL — without these, /api/oauth/google returns 503.
# Get from: https://console.cloud.google.com/apis/credentials
# Add authorized redirect: <APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth (Apple) ───────────────────────────────────────────────────────────
# OPTIONAL — without these, /api/oauth/apple returns 503.
# https://developer.apple.com/account/resources/identifiers
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# IMPORTANT: keep \n line breaks intact when pasting the .p8 file contents.
APPLE_PRIVATE_KEY=

# ── CORS ────────────────────────────────────────────────────────────────────
# REQUIRED. Comma-separated allowlist. Local default also allows 127.0.0.1.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174

# ── Object storage (Cloudflare R2, S3-compatible) ───────────────────────────
# REQUIRED for media uploads / CMS assets. Without R2 set, those endpoints fail.
# Get from: https://dash.cloudflare.com → R2.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=revolution-trading-media
R2_PUBLIC_URL=

# ── Stripe ──────────────────────────────────────────────────────────────────
# REQUIRED for checkout + payments. Test keys are fine for development.
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (Postmark) ────────────────────────────────────────────────────────
# Batch 6: empty token = graceful no-op. EmailService writes rows to
# `email_logs` with status='skipped_no_token' and skips the HTTP call.
# Set POSTMARK_TOKEN + POSTMARK_FROM_EMAIL + ADMIN_NOTIFICATION_EMAIL and
# restart the API to enable real delivery — no code change required.
POSTMARK_TOKEN=
POSTMARK_FROM_EMAIL=noreply@example.com
ADMIN_NOTIFICATION_EMAIL=
# Legacy alias for newsletter code; POSTMARK_FROM_EMAIL takes precedence.
FROM_EMAIL=noreply@example.com

# ── Search (Meilisearch) ────────────────────────────────────────────────────
# Local dev: docker-compose sets MEILISEARCH_HOST=http://meili:7700 and
# MEILISEARCH_API_KEY=dev-meili-master-key automatically — no entry needed here.
# Production: set to your Meilisearch Cloud instance values.
# Get from: https://cloud.meilisearch.com
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

# ── Video / Storage CDN (Bunny.net) ─────────────────────────────────────────
# OPTIONAL. Course videos and indicator file delivery use Bunny.
# Get from: https://bunny.net/
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_HOSTNAME=
BUNNY_CDN_URL=
